# Environment & secrets
.env
.env.*
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# NOTE (v2 #208): dist/ and build/ are NOT ignored here.
#   build/ = source (cloud_package.py).  dist/ = generated but git-TRACKED
#   (deploy-from-git + diff visibility). dist/ is excluded from mypy, not git.
# dist_tmp/ = throwaway variant/experiment build dir; NEVER committed over dist/.
dist_tmp/

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*

# LEAN local backtest output
# NOTE (v2 #208): removed legacy "/Results/" — on case-insensitive macOS it
# shadowed our tracked v2 results/ ledger. v2 BT output lives in backtests/.
/backtests/
*/backtests/
algorithm/*/backtests/
algorithm/performance_bct/backtests/
*.json.bak

# Databases (regenerable)
*.db

# Per-worktree LEAN config (local-id churns per worktree — not durable)
algorithm/performance_bct/config.json

# Universe-snapshot JSONs (regenerable; equity200 is the canonical tracked one)
algorithm/performance_bct/etf_universe_fy2025.json
algorithm/performance_bct/polygon_universe_daily_fy2025.json
algorithm/performance_bct/polygon_universe_equity_fy2025.json

# Root log files
*.log

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp

# Local backtest data dir (#208): zips are bulky+regenerable → ignored.
# But TRACK the dir's README + the data fingerprint MANIFEST (pins results to data state).
data/**
!data/README.md
!data/MANIFEST.json

# Claude Code harness local state (never project code)
.claude/worktrees/
.claude/scheduled_tasks.lock

# UI secrets and temp files
ui/.env.local
ui/temp-find-project.js
zz_handoffs/
lean_backtest.sh
data/kumo-qc.db

# BT output at any depth (archive/*/backtests etc)
**/backtests/

# QC backtest-output artifacts + signal cache (output, not source)
qc/
storage/

# GSD / planning scratch state (never project code)
.planning/

# Structure v2 (#208): sweep run workspaces are generated
sweeps/runs/
smoke_274/
