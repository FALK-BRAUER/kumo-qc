        "exit_rotation": {"module": "phases.exit_rotation.sell_worst_buy_best", "enabled": False, "params": {"min_score_delta": 2}},

        # ──────────────────────────────────────────────────────────────────
        # ADDS / PROFIT — disabled in baseline (retrofit later)
        # ──────────────────────────────────────────────────────────────────
        "adds": {
            "module": "phases.adds.pe_signal_renewed",
