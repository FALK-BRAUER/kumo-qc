"""
EXAMPLE main.py — kumo-qc phase-based strategy engine.

This is the canonical template for every strategy file.
Real strategies copy this structure and customize STRATEGY_CONFIG only.

See:
- docs/ARCHITECTURE.md — design rationale
- docs/PHASES.md       — per-phase contract spec
"""

from AlgorithmImports import *
from engine.engine import StrategyEngine

# =============================================================================
# STRATEGY DEFINITION — declarative, all phases listed
# =============================================================================
#
# How to read this:
#   - Every phase kind appears explicitly (even if disabled) for visibility.
#   - "module" = dotted path to the phase implementation.
#   - "enabled" = on/off toggle.
#   - "params" = phase-specific parameters (see PHASES.md for each).
#   - List-of-phases supported for: regime, portfolio_risk, exit_*, diagnostics.
#
# To create a new strategy: copy this file, rename STRATEGY_CONFIG.name,
# toggle phases on/off, tweak params. Engine handles the rest.
# =============================================================================

STRATEGY_CONFIG = {
    "name": "baseline-essentials-v1",
    "version": "1.0.0",
    "description": (
        "Baseline BCT strategy with validated essentials only. "
        "No pyramid, no boosters. Foundation for retrofit experiments."
    ),
    "tags": ["baseline", "bct", "ichimoku", "essentials"],
    "author": "fintrack HQ + du9j9gml (2026-05-30)",

    "phases": {
        # ──────────────────────────────────────────────────────────────────
        # UNIVERSE — daily eligible ticker set
        # ──────────────────────────────────────────────────────────────────
        "universe": {
            "module": "phases.universe.polygon_daily",
            "enabled": True,
            "params": {
                "min_price": 20.0,           # Falk threshold (vs Mark's $3)
                "min_dv": 500_000,           # min daily dollar volume
            },
        },

        # ──────────────────────────────────────────────────────────────────
        # SIGNAL — BCT 8-condition score per ticker
        # ──────────────────────────────────────────────────────────────────
        "signal": {
            "module": "phases.signal.bct_score",
            "enabled": True,
            "params": {
                "min_score": 7,              # strong signal stack (7/8 confluences)
