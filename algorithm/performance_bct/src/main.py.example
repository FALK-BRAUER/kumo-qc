        },

        # ──────────────────────────────────────────────────────────────────
        # REENTRY — after stop-out filter (disabled in baseline)
        # ──────────────────────────────────────────────────────────────────
        "reentry": {
            "module": "phases.reentry.cooldown_buy_stop",
