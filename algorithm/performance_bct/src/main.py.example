        },

        # ──────────────────────────────────────────────────────────────────
        # ELIGIBILITY — per-order pre-fire checks
        # ──────────────────────────────────────────────────────────────────
        "eligibility": {
            "module": "phases.eligibility.already_held_check",
            "enabled": True,
