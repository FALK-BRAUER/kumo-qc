        # ──────────────────────────────────────────────────────────────────
        "circuit_breaker": {
            "module": "phases.circuit_breaker.dd_reset",
            "enabled": False,
            "params": {"max_dd_pct": 15.0, "reset_after_days": 30},
        },
    },

    # ──────────────────────────────────────────────────────────────────────
    # CHARTER INVARIANTS — engine enforces at init, refuses to start if violated
    # ──────────────────────────────────────────────────────────────────────
    "invariants": {
        "no_count_caps": True,               # no max_positions / max_lots / max_entries_per_day
        "no_time_exits": True,               # no max_hold_days / exit_if_flat_after_days
        "explicit_exposure_only": True,      # implicit caps prohibited; #181
        "single_code_path": True,            # no if cloud / else local branches
