        # ──────────────────────────────────────────────────────────────────
        "regime": [
            {
                "module": "phases.regime.vix_threshold",
                "enabled": True,
                "params": {"max_vix": 25},   # E40d — confirmed essential
            },
            {
                "module": "phases.regime.spy_200ma",
                "enabled": True,
