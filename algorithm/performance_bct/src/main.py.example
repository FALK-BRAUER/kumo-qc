        },

        # ──────────────────────────────────────────────────────────────────
        # REBALANCE — engine tick scheduler
        # ──────────────────────────────────────────────────────────────────
        "rebalance": {
            "module": "phases.rebalance.daily_close",
            "enabled": True,
            "params": {"time": "16:05"},
        },

        # ──────────────────────────────────────────────────────────────────
        # DIAGNOSTICS — logging + parity (list, never blocks)
        # ──────────────────────────────────────────────────────────────────
        "diagnostics": [
            {
                "module": "phases.diagnostics.version_marker",
                "enabled": True,
                "params": {},
            },
            {
                "module": "phases.diagnostics.parity_logger",
                "enabled": True,
                "params": {"frequency": "daily"},
