# =============================================================================
# ENGINE BOOTSTRAP — algorithm class is a thin wrapper
# =============================================================================
# NO business logic here. Engine resolves phases, runs PHASE_ORDER, fires orders.
# =============================================================================

class BaselineEssentialsV1(QCAlgorithm):
    def Initialize(self):
        self.SetStartDate(2025, 1, 1)
        self.SetEndDate(2025, 12, 31)
        self.SetCash(100_000)

        # Single code path — same Initialize() for cloud + local.
        # Universe phase handles the data source unification.
        self.engine = StrategyEngine(STRATEGY_CONFIG, qc_algorithm=self)
        self.engine.initialize()

    def OnData(self, data):
        self.engine.on_data(data)

    def OnOrderEvent(self, order_event):
        self.engine.on_order_event(order_event)

    def OnSecuritiesChanged(self, changes):
        self.engine.on_securities_changed(changes)
